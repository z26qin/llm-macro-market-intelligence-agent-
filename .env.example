# Tavily API key — get one at https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxx

# Sentiment mode: "finbert" (default, requires torch + transformers) or "mock"
SENTIMENT_MODE=finbert

# vLLM endpoint — your self-hosted vLLM server (Nebius/AWS)
# VLLM_ENDPOINT=http://localhost:8000

# Optional: API key if your vLLM server requires authentication
# VLLM_API_KEY=

# Optional: Override the model name (default: meta-llama/Llama-3.3-70B-Instruct)
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
